{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@the-ruck/shared/*": ["../shared/src/*"],
      "@the-ruck/shared": ["../shared/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}

