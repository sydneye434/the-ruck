# Copy to .env (never commit .env). See README / Deployment.

# API port (Railway sets PORT automatically)
PORT=3001

NODE_ENV=development

# Directory for JSON data files (default: ./data relative to server cwd)
DATA_DIR=./data

# Allowed browser origin for CORS + Socket.io (your Netlify URL in production)
CLIENT_URL=http://localhost:5173

# Legacy alias — prefer CLIENT_URL
# CLIENT_ORIGIN=http://localhost:5173
